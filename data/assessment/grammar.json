{
  "name": "English grammar assessment bank",
  "version": 2,
  "note": "Covers all 21 curriculum topics (A1-B1 ~6 items each so a topic can lock; B2-C1 ~4 each). difficulty is hand-set; discrimination/guess (IRT) come with Psychometrics v5. AI-authored draft — needs human linguistic review before production.",
  "questions": [
    { "id": "art_01", "skill": "grammar", "topic": "nouns_articles", "cefr": "A2", "difficulty": 0.25, "question": "I have ___ apple and ___ banana.", "choices": ["a / a", "an / a", "an / an", "the / a"], "answer": 1, "explanation": "'an' before a vowel sound (apple), 'a' before a consonant sound (banana)." },
    { "id": "art_02", "skill": "grammar", "topic": "nouns_articles", "cefr": "A2", "difficulty": 0.30, "question": "She plays ___ piano very well.", "choices": ["a", "an", "the", "—"], "answer": 2, "explanation": "We use 'the' with musical instruments: play the piano." },
    { "id": "art_03", "skill": "grammar", "topic": "nouns_articles", "cefr": "B1", "difficulty": 0.45, "question": "Can you give me ___ advice?", "choices": ["a", "an", "some", "the"], "answer": 2, "explanation": "'Advice' is uncountable, so 'a/an' is wrong; 'some' fits." },
    { "id": "art_04", "skill": "grammar", "topic": "nouns_articles", "cefr": "B1", "difficulty": 0.50, "question": "He is ___ honest person.", "choices": ["a", "an", "the", "—"], "answer": 1, "explanation": "'Honest' has a silent 'h' (vowel sound), so use 'an'." },
    { "id": "art_05", "skill": "grammar", "topic": "nouns_articles", "cefr": "B2", "difficulty": 0.60, "question": "___ water in this bottle is warm.", "choices": ["The", "A", "An", "Some"], "answer": 0, "explanation": "Specific water (in this bottle) takes 'the'." },
    { "id": "art_06", "skill": "grammar", "topic": "nouns_articles", "cefr": "A2", "difficulty": 0.35, "question": "There are three ___ in the garden.", "choices": ["child", "childs", "children", "childrens"], "answer": 2, "explanation": "Irregular plural: one child, three children." },

    { "id": "psi_01", "skill": "grammar", "topic": "present_simple", "cefr": "A1", "difficulty": 0.15, "question": "She ___ to school every day.", "choices": ["go", "goes", "going", "gone"], "answer": 1, "explanation": "Third person singular adds -es: she goes." },
    { "id": "psi_02", "skill": "grammar", "topic": "present_simple", "cefr": "A1", "difficulty": 0.18, "question": "They ___ in London.", "choices": ["live", "lives", "living", "is live"], "answer": 0, "explanation": "Plural subject 'they' takes the base form: live." },
    { "id": "psi_03", "skill": "grammar", "topic": "present_simple", "cefr": "A2", "difficulty": 0.30, "question": "He ___ like coffee.", "choices": ["doesn't", "don't", "isn't", "not"], "answer": 0, "explanation": "Negative with he/she/it: doesn't + base form." },
    { "id": "psi_04", "skill": "grammar", "topic": "present_simple", "cefr": "A2", "difficulty": 0.32, "question": "___ she speak French?", "choices": ["Does", "Do", "Is", "Has"], "answer": 0, "explanation": "Question with she: Does + subject + base form." },
    { "id": "psi_05", "skill": "grammar", "topic": "present_simple", "cefr": "A1", "difficulty": 0.20, "question": "I ___ tennis on Sundays.", "choices": ["play", "plays", "playing", "am play"], "answer": 0, "explanation": "'I' takes the base form: play." },
    { "id": "psi_06", "skill": "grammar", "topic": "present_simple", "cefr": "A2", "difficulty": 0.35, "question": "Water ___ at 100 degrees.", "choices": ["boils", "boil", "is boiling", "boiled"], "answer": 0, "explanation": "General truth uses present simple: water boils." },

    { "id": "pco_01", "skill": "grammar", "topic": "present_continuous", "cefr": "A1", "difficulty": 0.22, "question": "Look! It ___.", "choices": ["is raining", "rains", "rained", "rain"], "answer": 0, "explanation": "Action happening now: is + -ing." },
    { "id": "pco_02", "skill": "grammar", "topic": "present_continuous", "cefr": "A2", "difficulty": 0.28, "question": "They ___ TV right now.", "choices": ["are watching", "watch", "watches", "is watching"], "answer": 0, "explanation": "'They' + are + -ing for an action in progress." },
    { "id": "pco_03", "skill": "grammar", "topic": "present_continuous", "cefr": "A2", "difficulty": 0.34, "question": "I ___ for my keys at the moment.", "choices": ["am looking", "look", "looks", "looked"], "answer": 0, "explanation": "'At the moment' signals present continuous: am looking." },
    { "id": "pco_04", "skill": "grammar", "topic": "present_continuous", "cefr": "A2", "difficulty": 0.30, "question": "She ___ a book now.", "choices": ["is reading", "reads", "read", "reading"], "answer": 0, "explanation": "'Now' + is + -ing." },
    { "id": "pco_05", "skill": "grammar", "topic": "present_continuous", "cefr": "B1", "difficulty": 0.48, "question": "We ___ to Spain next week.", "choices": ["are flying", "fly", "flies", "flew"], "answer": 0, "explanation": "Present continuous can express a fixed future arrangement." },
    { "id": "pco_06", "skill": "grammar", "topic": "present_continuous", "cefr": "A2", "difficulty": 0.40, "question": "Why ___ you ___ at me?", "choices": ["are / looking", "do / look", "is / looking", "are / look"], "answer": 0, "explanation": "Continuous question: are + subject + -ing." },

    { "id": "pst_01", "skill": "grammar", "topic": "past_simple", "cefr": "A1", "difficulty": 0.22, "question": "I ___ to the cinema yesterday.", "choices": ["went", "go", "gone", "going"], "answer": 0, "explanation": "Irregular past of go is 'went'." },
    { "id": "pst_02", "skill": "grammar", "topic": "past_simple", "cefr": "A2", "difficulty": 0.30, "question": "She ___ her homework last night.", "choices": ["did", "done", "do", "does"], "answer": 0, "explanation": "Past simple of do is 'did'." },
    { "id": "pst_03", "skill": "grammar", "topic": "past_simple", "cefr": "A2", "difficulty": 0.32, "question": "They ___ a great time at the party.", "choices": ["had", "have", "has", "having"], "answer": 0, "explanation": "Past simple of have is 'had'." },
    { "id": "pst_04", "skill": "grammar", "topic": "past_simple", "cefr": "A2", "difficulty": 0.38, "question": "___ you ___ the film?", "choices": ["Did / see", "Did / saw", "Do / see", "Have / see"], "answer": 0, "explanation": "Past question: Did + subject + base form (see)." },
    { "id": "pst_05", "skill": "grammar", "topic": "past_simple", "cefr": "A2", "difficulty": 0.34, "question": "He ___ to me last week.", "choices": ["spoke", "speak", "spoken", "speaks"], "answer": 0, "explanation": "Irregular past of speak is 'spoke'." },
    { "id": "pst_06", "skill": "grammar", "topic": "past_simple", "cefr": "A2", "difficulty": 0.30, "question": "We ___ at home all day.", "choices": ["stayed", "stay", "staid", "staying"], "answer": 0, "explanation": "Regular past: stay + -ed = stayed." },

    { "id": "ff_01", "skill": "grammar", "topic": "future_forms", "cefr": "A2", "difficulty": 0.35, "question": "I think it ___ rain tomorrow.", "choices": ["will", "is", "does", "would"], "answer": 0, "explanation": "Prediction with 'I think' uses 'will'." },
    { "id": "ff_02", "skill": "grammar", "topic": "future_forms", "cefr": "A2", "difficulty": 0.38, "question": "We ___ visit grandma this weekend.", "choices": ["are going to", "will to", "go to", "going"], "answer": 0, "explanation": "A plan/intention uses 'be going to' + base form." },
    { "id": "ff_03", "skill": "grammar", "topic": "future_forms", "cefr": "B1", "difficulty": 0.45, "question": "Look at those clouds! It ___ rain.", "choices": ["is going to", "will", "goes to", "would"], "answer": 0, "explanation": "Present evidence (clouds) → 'be going to'." },
    { "id": "ff_04", "skill": "grammar", "topic": "future_forms", "cefr": "B1", "difficulty": 0.52, "question": "I'll call you when I ___ home.", "choices": ["get", "will get", "got", "am getting"], "answer": 0, "explanation": "After 'when' for the future, use the present simple." },
    { "id": "ff_05", "skill": "grammar", "topic": "future_forms", "cefr": "B1", "difficulty": 0.48, "question": "The train ___ at 6 pm.", "choices": ["leaves", "will leave", "is leaving", "left"], "answer": 0, "explanation": "Timetables take the present simple: leaves." },
    { "id": "ff_06", "skill": "grammar", "topic": "future_forms", "cefr": "B1", "difficulty": 0.50, "question": "A: The phone's ringing. B: I ___ it.", "choices": ["'ll get", "get", "'m getting", "am going to get"], "answer": 0, "explanation": "A spontaneous decision uses 'will'." },

    { "id": "cu_01", "skill": "grammar", "topic": "countable_uncountable", "cefr": "A2", "difficulty": 0.32, "question": "How ___ sugar do you want?", "choices": ["much", "many", "some", "few"], "answer": 0, "explanation": "'Sugar' is uncountable → 'how much'." },
    { "id": "cu_02", "skill": "grammar", "topic": "countable_uncountable", "cefr": "A2", "difficulty": 0.34, "question": "There aren't ___ apples left.", "choices": ["many", "much", "a little", "a much"], "answer": 0, "explanation": "Countable plural (apples) → 'many'." },
    { "id": "cu_03", "skill": "grammar", "topic": "countable_uncountable", "cefr": "B1", "difficulty": 0.48, "question": "I only have ___ money.", "choices": ["a little", "a few", "many", "less of"], "answer": 0, "explanation": "Uncountable (money) → 'a little'." },
    { "id": "cu_04", "skill": "grammar", "topic": "countable_uncountable", "cefr": "B1", "difficulty": 0.48, "question": "She has ___ friends here.", "choices": ["a few", "a little", "much", "less"], "answer": 0, "explanation": "Countable plural (friends) → 'a few'." },
    { "id": "cu_05", "skill": "grammar", "topic": "countable_uncountable", "cefr": "A2", "difficulty": 0.30, "question": "Could I have ___ water?", "choices": ["some", "a", "many", "an"], "answer": 0, "explanation": "Uncountable in a request → 'some'." },
    { "id": "cu_06", "skill": "grammar", "topic": "countable_uncountable", "cefr": "B1", "difficulty": 0.46, "question": "There is too ___ traffic today.", "choices": ["much", "many", "few", "lots"], "answer": 0, "explanation": "Uncountable (traffic) → 'too much'." },

    { "id": "cmp_01", "skill": "grammar", "topic": "comparatives", "cefr": "A2", "difficulty": 0.30, "question": "This box is ___ than that one.", "choices": ["heavier", "heavy", "heaviest", "more heavy"], "answer": 0, "explanation": "Short adjective + -er: heavier." },
    { "id": "cmp_02", "skill": "grammar", "topic": "comparatives", "cefr": "A2", "difficulty": 0.34, "question": "She is the ___ student in the class.", "choices": ["best", "better", "good", "most good"], "answer": 0, "explanation": "Irregular superlative of good is 'best'." },
    { "id": "cmp_03", "skill": "grammar", "topic": "comparatives", "cefr": "A2", "difficulty": 0.30, "question": "Today is ___ than yesterday.", "choices": ["hotter", "hot", "hottest", "more hot"], "answer": 0, "explanation": "Short adjective doubles the consonant: hotter." },
    { "id": "cmp_04", "skill": "grammar", "topic": "comparatives", "cefr": "B1", "difficulty": 0.44, "question": "This film is ___ interesting than the book.", "choices": ["more", "most", "much", "very"], "answer": 0, "explanation": "Long adjective uses 'more ... than'." },
    { "id": "cmp_05", "skill": "grammar", "topic": "comparatives", "cefr": "B1", "difficulty": 0.42, "question": "He runs ___ than his brother.", "choices": ["faster", "fast", "fastest", "more fast"], "answer": 0, "explanation": "Comparative adverb: faster." },
    { "id": "cmp_06", "skill": "grammar", "topic": "comparatives", "cefr": "B1", "difficulty": 0.46, "question": "It's the ___ expensive restaurant in town.", "choices": ["most", "more", "much", "very"], "answer": 0, "explanation": "Long adjective superlative uses 'the most'." },

    { "id": "pp_01", "skill": "grammar", "topic": "present_perfect", "cefr": "B1", "difficulty": 0.40, "question": "___ you ever ___ to Japan?", "choices": ["Have / been", "Did / go", "Have / went", "Do / go"], "answer": 0, "explanation": "Experience: have + past participle (been)." },
    { "id": "pp_02", "skill": "grammar", "topic": "present_perfect", "cefr": "B1", "difficulty": 0.45, "question": "She ___ here since 2019.", "choices": ["has lived", "lived", "is living", "lives"], "answer": 0, "explanation": "'Since' + unfinished period → present perfect." },
    { "id": "pp_03", "skill": "grammar", "topic": "present_perfect", "cefr": "B2", "difficulty": 0.60, "question": "We ___ each other for ten years.", "choices": ["have known", "knew", "have been knowing", "know"], "answer": 0, "explanation": "Stative 'know' uses simple present perfect, not continuous." },
    { "id": "pp_04", "skill": "grammar", "topic": "present_perfect", "cefr": "B2", "difficulty": 0.60, "question": "He ___ his keys, so he can't get in now.", "choices": ["has lost", "lost", "loses", "is losing"], "answer": 0, "explanation": "Past action with a present result → present perfect." },
    { "id": "pp_05", "skill": "grammar", "topic": "present_perfect", "cefr": "B1", "difficulty": 0.45, "question": "I ___ this film three times already.", "choices": ["have seen", "saw", "have saw", "see"], "answer": 0, "explanation": "'Already' + experience → present perfect; participle 'seen'." },
    { "id": "pp_06", "skill": "grammar", "topic": "present_perfect", "cefr": "B1", "difficulty": 0.42, "question": "I ___ finished my work yet.", "choices": ["haven't", "didn't", "don't", "wasn't"], "answer": 0, "explanation": "'Yet' in negatives uses present perfect: haven't finished." },

    { "id": "mod_01", "skill": "grammar", "topic": "modals", "cefr": "A2", "difficulty": 0.38, "question": "You ___ smoke here. It's forbidden.", "choices": ["mustn't", "don't have to", "couldn't", "wouldn't"], "answer": 0, "explanation": "Prohibition uses 'mustn't'." },
    { "id": "mod_02", "skill": "grammar", "topic": "modals", "cefr": "B1", "difficulty": 0.44, "question": "You ___ see a doctor.", "choices": ["should", "must to", "ought", "would"], "answer": 0, "explanation": "Advice uses 'should' + base form." },
    { "id": "mod_03", "skill": "grammar", "topic": "modals", "cefr": "B1", "difficulty": 0.46, "question": "___ I open the window?", "choices": ["May", "Must", "Would", "Shall"], "answer": 0, "explanation": "Polite request for permission: 'May I ...?'" },
    { "id": "mod_04", "skill": "grammar", "topic": "modals", "cefr": "B1", "difficulty": 0.55, "question": "She ___ be at home; her car is here.", "choices": ["must", "can", "should", "would"], "answer": 0, "explanation": "Logical deduction (almost certain) uses 'must'." },
    { "id": "mod_05", "skill": "grammar", "topic": "modals", "cefr": "B1", "difficulty": 0.48, "question": "We ___ finish by Friday.", "choices": ["have to", "must to", "should to", "ought"], "answer": 0, "explanation": "Obligation: 'have to' + base form." },
    { "id": "mod_06", "skill": "grammar", "topic": "modals", "cefr": "B2", "difficulty": 0.62, "question": "You ___ have told me earlier!", "choices": ["should", "must", "can", "would"], "answer": 0, "explanation": "Criticism of a past action: 'should have' + participle." },

    { "id": "cond_01", "skill": "grammar", "topic": "conditionals_1_2", "cefr": "B1", "difficulty": 0.40, "question": "If it ___ tomorrow, we'll stay home.", "choices": ["rains", "will rain", "rained", "would rain"], "answer": 0, "explanation": "First conditional: present simple in the if-clause." },
    { "id": "cond_02", "skill": "grammar", "topic": "conditionals_1_2", "cefr": "B1", "difficulty": 0.50, "question": "If I ___ rich, I would travel the world.", "choices": ["were", "am", "will be", "had been"], "answer": 0, "explanation": "Second conditional (unreal present): if + past." },
    { "id": "cond_03", "skill": "grammar", "topic": "conditionals_1_2", "cefr": "B1", "difficulty": 0.50, "question": "She would call you if she ___ your number.", "choices": ["had", "has", "will have", "would have"], "answer": 0, "explanation": "Second conditional if-clause uses the past simple." },
    { "id": "cond_04", "skill": "grammar", "topic": "conditionals_1_2", "cefr": "B2", "difficulty": 0.58, "question": "If you ___ harder, you would pass the exam.", "choices": ["studied", "study", "will study", "had studied"], "answer": 0, "explanation": "Second conditional pairs past simple with 'would'." },
    { "id": "cond_05", "skill": "grammar", "topic": "conditionals_1_2", "cefr": "B2", "difficulty": 0.58, "question": "If I ___ you, I wouldn't worry about it.", "choices": ["were", "was", "am", "would be"], "answer": 0, "explanation": "Fixed advice form: 'If I were you...'." },
    { "id": "cond_06", "skill": "grammar", "topic": "conditionals_1_2", "cefr": "B1", "difficulty": 0.52, "question": "Unless you hurry, you ___ the bus.", "choices": ["will miss", "miss", "would miss", "missed"], "answer": 0, "explanation": "'Unless' = if not; first conditional → 'will' in the main clause." },

    { "id": "pas_01", "skill": "grammar", "topic": "passive_voice", "cefr": "B1", "difficulty": 0.45, "question": "The window ___ by the boys yesterday.", "choices": ["was broken", "broke", "is broken", "has broken"], "answer": 0, "explanation": "Past passive: was/were + past participle." },
    { "id": "pas_02", "skill": "grammar", "topic": "passive_voice", "cefr": "B1", "difficulty": 0.40, "question": "English ___ all over the world.", "choices": ["is spoken", "speaks", "is speaking", "spoken"], "answer": 0, "explanation": "Present passive: is/are + past participle." },
    { "id": "pas_03", "skill": "grammar", "topic": "passive_voice", "cefr": "B2", "difficulty": 0.60, "question": "The new bridge ___ next year.", "choices": ["will be built", "will build", "is built", "builds"], "answer": 0, "explanation": "Future passive: will be + past participle." },
    { "id": "pas_04", "skill": "grammar", "topic": "passive_voice", "cefr": "B2", "difficulty": 0.65, "question": "This song ___ by millions of people so far.", "choices": ["has been heard", "has heard", "is hearing", "heard"], "answer": 0, "explanation": "Present perfect passive: has been + past participle." },
    { "id": "pas_05", "skill": "grammar", "topic": "passive_voice", "cefr": "B1", "difficulty": 0.45, "question": "The letters ___ every morning.", "choices": ["are delivered", "deliver", "is delivered", "delivering"], "answer": 0, "explanation": "Plural subject + are + past participle." },
    { "id": "pas_06", "skill": "grammar", "topic": "passive_voice", "cefr": "B1", "difficulty": 0.52, "question": "Where ___ this car ___?", "choices": ["was / made", "did / make", "was / make", "is / made"], "answer": 0, "explanation": "Past passive question: was + subject + past participle." },

    { "id": "rc_01", "skill": "grammar", "topic": "relative_clauses", "cefr": "A2", "difficulty": 0.38, "question": "The man ___ lives next door is a doctor.", "choices": ["who", "which", "whom", "what"], "answer": 0, "explanation": "'Who' for people as the subject." },
    { "id": "rc_02", "skill": "grammar", "topic": "relative_clauses", "cefr": "B1", "difficulty": 0.45, "question": "That's the book ___ I told you about.", "choices": ["which", "who", "whose", "where"], "answer": 0, "explanation": "'Which' for things." },
    { "id": "rc_03", "skill": "grammar", "topic": "relative_clauses", "cefr": "B1", "difficulty": 0.55, "question": "She's the woman ___ son won the prize.", "choices": ["whose", "who", "which", "who's"], "answer": 0, "explanation": "'Whose' shows possession." },
    { "id": "rc_04", "skill": "grammar", "topic": "relative_clauses", "cefr": "B1", "difficulty": 0.50, "question": "This is the house ___ I was born.", "choices": ["where", "which", "who", "when"], "answer": 0, "explanation": "'Where' for places." },
    { "id": "rc_05", "skill": "grammar", "topic": "relative_clauses", "cefr": "B2", "difficulty": 0.60, "question": "My friend, ___ lives in Paris, is visiting.", "choices": ["who", "which", "that", "whom"], "answer": 0, "explanation": "Non-defining clause about a person uses 'who' (not 'that')." },
    { "id": "rc_06", "skill": "grammar", "topic": "relative_clauses", "cefr": "B1", "difficulty": 0.48, "question": "Do you remember the day ___ we met?", "choices": ["when", "where", "which", "who"], "answer": 0, "explanation": "'When' for time." },

    { "id": "gi_01", "skill": "grammar", "topic": "gerunds_infinitives", "cefr": "B1", "difficulty": 0.44, "question": "I enjoy ___ to music.", "choices": ["listening", "to listen", "listen", "listened"], "answer": 0, "explanation": "'Enjoy' is followed by the -ing form." },
    { "id": "gi_02", "skill": "grammar", "topic": "gerunds_infinitives", "cefr": "B1", "difficulty": 0.42, "question": "She wants ___ a doctor.", "choices": ["to be", "being", "be", "been"], "answer": 0, "explanation": "'Want' is followed by the to-infinitive." },
    { "id": "gi_03", "skill": "grammar", "topic": "gerunds_infinitives", "cefr": "B1", "difficulty": 0.46, "question": "He's good at ___.", "choices": ["cooking", "cook", "to cook", "cooked"], "answer": 0, "explanation": "After a preposition ('at'), use the -ing form." },
    { "id": "gi_04", "skill": "grammar", "topic": "gerunds_infinitives", "cefr": "B2", "difficulty": 0.55, "question": "I decided ___ early.", "choices": ["to leave", "leaving", "leave", "left"], "answer": 0, "explanation": "'Decide' is followed by the to-infinitive." },
    { "id": "gi_05", "skill": "grammar", "topic": "gerunds_infinitives", "cefr": "B1", "difficulty": 0.50, "question": "Would you mind ___ the door?", "choices": ["closing", "to close", "close", "closed"], "answer": 0, "explanation": "'Mind' is followed by the -ing form." },
    { "id": "gi_06", "skill": "grammar", "topic": "gerunds_infinitives", "cefr": "B2", "difficulty": 0.56, "question": "We can't afford ___ a new car.", "choices": ["to buy", "buying", "buy", "bought"], "answer": 0, "explanation": "'Afford' is followed by the to-infinitive." },

    { "id": "rs_01", "skill": "grammar", "topic": "reported_speech", "cefr": "B1", "difficulty": 0.50, "question": "She said she ___ tired.", "choices": ["was", "is", "has been", "will be"], "answer": 0, "explanation": "Backshift: present 'is' becomes past 'was' in reported speech." },
    { "id": "rs_02", "skill": "grammar", "topic": "reported_speech", "cefr": "B2", "difficulty": 0.60, "question": "He told me he ___ the next day.", "choices": ["would come", "will come", "comes", "came"], "answer": 0, "explanation": "'will' backshifts to 'would'." },
    { "id": "rs_03", "skill": "grammar", "topic": "reported_speech", "cefr": "B2", "difficulty": 0.62, "question": "They asked where I ___.", "choices": ["lived", "live", "do live", "am living"], "answer": 0, "explanation": "Reported question uses statement word order and backshift." },
    { "id": "rs_04", "skill": "grammar", "topic": "reported_speech", "cefr": "B2", "difficulty": 0.60, "question": "She asked if I ___ help her.", "choices": ["could", "can", "will", "may"], "answer": 0, "explanation": "'can' backshifts to 'could'." },

    { "id": "ppf_01", "skill": "grammar", "topic": "past_perfect", "cefr": "B1", "difficulty": 0.52, "question": "When we arrived, the film ___ already ___.", "choices": ["had / started", "has / started", "did / start", "was / start"], "answer": 0, "explanation": "Earlier past action: had + past participle." },
